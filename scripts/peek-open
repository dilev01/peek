#!/bin/bash
# Open peek in a new Terminal.app window.
# Uses a .command file to guarantee a new window (not a tab).
# Usage: peek-open <file.md>
# Usage: peek-open --find <keyword>

PEEK_BIN="$HOME/personal/peek/bin/peek"

# Create a temporary .command file — Terminal.app always opens these in a new window.
TMPSCRIPT=$(mktemp /tmp/peek-run-XXXXXX)
mv "$TMPSCRIPT" "${TMPSCRIPT}.command"
TMPSCRIPT="${TMPSCRIPT}.command"

cat > "$TMPSCRIPT" << EOF
#!/bin/bash
clear
"$PEEK_BIN" $@
rm "\$0"
exit
EOF
chmod +x "$TMPSCRIPT"

open "$TMPSCRIPT"
